generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                    Int                  @id @default(autoincrement())
  username              String               @unique(map: "username") @db.VarChar(50)
  email                 String?              @unique(map: "email") @db.VarChar(100)
  password_hash         String               @db.VarChar(255)
  first_name            String               @db.VarChar(50)
  last_name             String               @db.VarChar(50)
  is_active             Boolean?             @default(true)
  created_at            DateTime             @default(now()) @db.Timestamp(0)
  team                  String?              @db.VarChar(100)
  status                String?              @default("active") @db.VarChar(50)
  province              String?              @db.VarChar(100)
  phone                 String?              @db.VarChar(20)
  avatar                String?              @db.VarChar(255)
  functional_role       String?              @db.VarChar(100)
  role_id               Int?
  join_date             DateTime?            @db.Date
  is_trial              Boolean?             @default(false)
  attendance_percentage Decimal?             @default(92.00) @db.Decimal(5, 2)
  
  // ⭐ DODAJ TE POLA:
  form_data             String?              @db.LongText   // JSON z dodatkowymi danymi (zainteresowania, umiejętności, kontakty itp.)
  // ⭐ LUB jeśli chcesz osobne pola:
  // interests            String?              @db.LongText   // JSON array
  // skills               String?              @db.LongText   // JSON array
  // sm_areas             String?              @db.LongText   // JSON array
  // training_areas       String?              @db.LongText   // JSON array
  // contribution_status  String?              @default("paid") @db.VarChar(50)
  // arrears              Decimal?             @default(0) @db.Decimal(10, 2)
  // sala_contacts        String?              @db.LongText   // JSON array
  // mp_contacts          String?              @db.LongText   // JSON array
  // other_contacts       String?              @db.LongText   // JSON array

  guides                Guide[]
  notifications         Notification[]
  onboarding_data       onboarding_data[]
  projects              Project[]
  refresh_tokens        refresh_tokens[]
  team_members          TeamMember[]
  user_notifications    user_notifications[]
  roles                 roles?               @relation(fields: [role_id], references: [id], onUpdate: Restrict, map: "users_ibfk_1")

  @@index([role_id], map: "idx_users_role_id")
  @@index([status], map: "idx_users_status")
  @@map("users")
}

model Project {
  id             Int       @id @default(autoincrement())
  name           String    @db.VarChar(255)
  description    String?   @db.Text
  pillar         String?   @db.VarChar(100)
  coordinator_id Int?
  team           String?   @db.VarChar(100)
  status         String?   @default("planning") @db.VarChar(50)
  estimated_end  DateTime? @db.Date
  created_at     DateTime  @default(now()) @db.Timestamp(0)
  updated_at     DateTime  @default(now()) @updatedAt @db.Timestamp(0)
  is_active      Int?      @default(1) @db.TinyInt
  users          User?     @relation(fields: [coordinator_id], references: [id], onUpdate: Restrict, map: "projects_ibfk_1")

  @@index([coordinator_id], map: "coordinator_id")
  @@index([status], map: "idx_projects_status")
  @@map("projects")
}

model Notification {
  id                 Int                  @id @default(autoincrement())
  user_id            Int
  title              String               @db.VarChar(255)
  message            String               @db.Text
  type               String               @db.VarChar(50)
  read               Boolean?             @default(false)
  link               String?              @db.VarChar(255)
  target             String?              @default("all") @db.VarChar(50)
  created_at         DateTime             @default(now()) @db.Timestamp(0)
  updated_at         DateTime             @default(now()) @db.Timestamp(0)
  user               User                 @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "notifications_ibfk_1")
  user_notifications user_notifications[]

  @@index([created_at], map: "idx_notifications_created_at")
  @@index([read], map: "idx_notifications_read")
  @@index([user_id], map: "idx_notifications_user_id")
  @@map("notifications")
}

model Team {
  id          Int          @id @default(autoincrement())
  name        String       @db.VarChar(100)
  role        String       @db.VarChar(100)
  description String?      @db.Text
  icon        String?      @default("Users") @db.VarChar(50)
  status      String?      @default("active") @db.VarChar(20)
  parent_id   Int?
  email       String?      @db.VarChar(255)
  created_at  DateTime     @default(now()) @db.Timestamp(0)
  members     TeamMember[]
  parent      Team?        @relation("TeamParent", fields: [parent_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "teams_ibfk_1")
  childTeams  Team[]       @relation("TeamParent")

  @@index([parent_id], map: "parent_id")
  @@map("teams")
}

model TeamMember {
  id         Int      @id @default(autoincrement())
  team_id    Int
  user_id    Int
  role       String   @db.VarChar(100)
  created_at DateTime @default(now()) @db.Timestamp(0)
  is_leader  Boolean? @default(false)
  team       Team     @relation(fields: [team_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "team_members_ibfk_1")
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "team_members_ibfk_2")

  @@unique([team_id, user_id], map: "unique_team_user")
  @@index([user_id], map: "user_id")
  @@map("team_members")
}

model Guide {
  id               Int      @id @default(autoincrement())
  title            String   @db.VarChar(255)
  description      String?  @db.Text
  category         String?  @db.VarChar(50)
  access           String?  @default("all") @db.VarChar(50)
  author_id        Int?
  content          String?  @db.LongText
  created_at       DateTime @default(now()) @db.Timestamp(0)
  updated_at       DateTime @default(now()) @updatedAt @db.Timestamp(0)
  is_published     Int?     @default(1) @db.TinyInt
  attachments      String?  @db.LongText
  functional_roles String?  @db.LongText
  author           User?    @relation(fields: [author_id], references: [id], onUpdate: Restrict, map: "guides_ibfk_1")

  @@index([author_id], map: "author_id")
  @@index([created_at], map: "idx_guides_created_at")
  @@map("guides")
}

model onboarding_data {
  id                   Int      @id @default(autoincrement())
  user_id              Int
  first_name           String   @db.VarChar(100)
  last_name            String   @db.VarChar(100)
  email                String   @db.VarChar(255)
  phone                String?  @db.VarChar(20)
  province             String   @db.VarChar(100)
  development_areas    String   @db.LongText
  skills               String?  @db.LongText
  experience           String?  @default("none") @db.VarChar(50)
  availability         String?  @db.Text
  description          String?  @db.Text
  sala_contacts        String?  @db.LongText
  mp_contacts          String?  @db.LongText
  institution_contacts String?  @db.LongText
  other_contacts       String?  @db.LongText
  completed            Boolean? @default(false)
  created_at           DateTime @default(now()) @db.Timestamp(0)
  updated_at           DateTime @default(now()) @db.Timestamp(0)
  users                User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "onboarding_data_ibfk_1")

  @@index([completed], map: "idx_onboarding_completed")
  @@index([user_id], map: "idx_onboarding_user_id")
}

model refresh_tokens {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token      String   @db.VarChar(512)
  expires_at DateTime @db.DateTime(0)
  created_at DateTime @default(now()) @db.Timestamp(0)
  users      User     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "refresh_tokens_ibfk_1")

  @@index([user_id], map: "user_id")
}

model roles {
  id          Int      @id @default(autoincrement())
  name        String   @unique(map: "name") @db.VarChar(50)
  description String?  @db.Text
  created_at  DateTime @default(now()) @db.Timestamp(0)
  users       User[]
}

model user_notifications {
  id              Int          @id @default(autoincrement())
  user_id         Int
  notification_id Int
  read            Boolean?     @default(false)
  read_at         DateTime?    @db.Timestamp(0)
  created_at      DateTime     @default(now()) @db.Timestamp(0)
  users           User         @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "user_notifications_ibfk_1")
  notifications   Notification @relation(fields: [notification_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "user_notifications_ibfk_2")

  @@unique([user_id, notification_id], map: "unique_user_notification")
  @@index([user_id, read], map: "idx_user_notifications_user_read")
  @@index([notification_id], map: "notification_id")
}
